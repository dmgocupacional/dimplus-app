{
  "expo": {
    "name": "DIM+ Saúde",
    "slug": "dimplus-app",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "dimplus",
    "userInterfaceStyle": "light",
    "android": {
      "package": "br.com.dimmaissaude.app",
      "adaptiveIcon": {
        "backgroundColor": "#202745",
        "foregroundImage": "./assets/brand/icon-adaptive.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#202745",
          "image": "./assets/brand/logo-white.png",
          "imageWidth": 140
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "br.com.dimmaissaude.app",
      "supportsTablet": false
    }
  }
}