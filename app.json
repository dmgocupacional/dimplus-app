{
  "expo": {
    "name": "DIM+ Saúde",
    "slug": "dimplus",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "dimplus",
    "userInterfaceStyle": "light",
    "android": {
      "package": "br.com.dimmaissaude.app",
      "adaptiveIcon": {
        "backgroundColor": "#202745",
        "foregroundImage": "./assets/brand/icon-adaptive.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#202745",
          "image": "./assets/brand/logo-white.png",
          "imageWidth": 140
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "br.com.dimmaissaude.app",
      "supportsTablet": false
    },
    "extra": {
      "eas": {
        "projectId": "2147d4ae-6bfc-4c81-b582-1b115af6b830"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/2147d4ae-6bfc-4c81-b582-1b115af6b830"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "dimpluss-team"
  }
}